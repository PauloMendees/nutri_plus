{
  "name": "nutri-plus",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "mobile": "pnpm --filter @nutri-plus/mobile start",
    "mobile:clear": "pnpm --filter @nutri-plus/mobile start -- --clear",
    "mobile:ios": "pnpm --filter @nutri-plus/mobile ios",
    "mobile:android": "pnpm --filter @nutri-plus/mobile android"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.4"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.15",
      "@types/react-dom": "19.2.3"
    }
  }
}
